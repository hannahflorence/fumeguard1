# MQTT — HiveMQ Cloud (primary)
# Cluster → Access Details in https://console.hivemq.cloud
MQTT_URL=mqtts://xxxxxx.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password

# Optional: local Mosquitto (npm run broker) for offline dev
# MQTT_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Firebase — use emulator for local dev
USE_FIREBASE_EMULATOR=true
FIREBASE_PROJECT_ID=fumeguard-demo
FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000
# Production: path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Server
PORT=3001
DEVICE_ID=esp32-01
HISTORY_INTERVAL_MS=5000

# Web (Vite — prefix VITE_)
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_DATABASE_URL=http://127.0.0.1:9000?ns=fumeguard-demo-default-rtdb
VITE_FIREBASE_PROJECT_ID=fumeguard-demo
VITE_USE_FIREBASE_EMULATOR=true
VITE_FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_DATABASE_EMULATOR_PORT=9000
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_AUTH_EMULATOR_PORT=9099
VITE_DEVICE_ID=esp32-01
