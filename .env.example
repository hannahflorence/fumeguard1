# MQTT — HiveMQ Cloud (primary)
# Cluster → Access Details in https://console.hivemq.cloud
MQTT_URL=mqtts://xxxxxx.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password

# Optional: local Mosquitto (npm run broker) for offline dev
# MQTT_URL=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Firebase — use emulator for local dev
USE_FIREBASE_EMULATOR=false
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Server
PORT=3001
DEVICE_ID=esp32-01
HISTORY_INTERVAL_MS=5000

# Web (Vite — prefix VITE_)
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_USE_FIREBASE_EMULATOR=false
VITE_DEVICE_ID=esp32-01
VITE_BRIDGE_HEALTH_URL=http://localhost:3001/health
