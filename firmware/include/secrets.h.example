#pragma once

// Copy to secrets.h and fill in your network credentials.
#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// --- MQTT: HiveMQ Cloud (recommended) ---
// From HiveMQ Cloud console → Cluster → Access Details
#define MQTT_HOST       "xxxxxx.s1.eu.hivemq.cloud"  // Cluster URL (no mqtt:// prefix)
#define MQTT_PORT       8883
#define MQTT_USER       "your-hivemq-username"
#define MQTT_PASS       "your-hivemq-password"
#define MQTT_SECURE     true                         // TLS required for HiveMQ Cloud

// --- Optional: local Mosquitto (docker compose) for offline dev ---
// #define MQTT_HOST       "192.168.1.100"
// #define MQTT_PORT       1883
// #define MQTT_USER       ""
// #define MQTT_PASS       ""
